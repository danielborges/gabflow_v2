APP_ENV=development
APP_RELEASE=local
WEB_PORT=8080

POSTGRES_DB=gabflow
POSTGRES_USER=gabflow
POSTGRES_PASSWORD=troque-esta-senha-do-banco

SECRET_KEY=gere-uma-chave-aleatoria-com-pelo-menos-32-bytes
JWT_SECRET_KEY=gere-outra-chave-aleatoria-com-pelo-menos-32-bytes
COOKIE_SECURE=false

SEED_ADMIN_ON_START=true
SEED_TENANT=gabinete-demo
SEED_ADMIN_EMAIL=admin@gabflow.local
SEED_ADMIN_PASSWORD=troque-esta-senha-administrativa

SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

RESEND_API_KEY=
RESEND_FROM_EMAIL=GabFlow <atendimento@envios.seudominio.gov.br>
RESEND_TIMEOUT_SECONDS=10

WORKER_POLL_SECONDS=2
WORKER_BATCH_SIZE=20
WORKER_MAX_ATTEMPTS=5
WORKER_RETRY_BASE_SECONDS=30
WORKER_RETRY_MAX_SECONDS=3600
WORKER_LOCK_TIMEOUT_SECONDS=300
SCHEDULER_INTERVAL_SECONDS=30

AI_TRIAGE_PROVIDER=ollama
AI_TRIAGE_MODEL=qwen2.5:3b
AI_TRIAGE_FALLBACK_MODEL=gabflow-triage-rules-v1
AI_TRIAGE_PROMPT_VERSION=triage-v2
AI_TRIAGE_TIMEOUT_SECONDS=120
AI_TRIAGE_FALLBACK_ENABLED=true
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_KEEP_ALIVE=10m

MAX_ATTACHMENT_BYTES=15728640
ATTACHMENT_TOKEN_MAX_AGE=300
